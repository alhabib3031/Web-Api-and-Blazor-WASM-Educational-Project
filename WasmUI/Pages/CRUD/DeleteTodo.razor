@page "/delete-todo"

@inject NavigationManager NavigationManager
@inject ITodoClientService _todoClientService 
@attribute [Authorize]

<div class="mx-auto mt-4" style="max-width: 500px;">
    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Delete Todo Item</h3>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="mt-3 rounded-md border border-blue-700 bg-blue-900/50 p-4 text-blue-200">@statusMessage</div>
    }

    <div class="mt-3 rounded-lg bg-white p-5 shadow-md dark:bg-gray-800">
        <div class="mb-4">
            <label for="deleteId" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Enter Todo ID to Delete:</label>
            <input type="number" id="deleteId" @bind="targetId" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-400 sm:text-sm" placeholder="Ex: 10" />
        </div>

        @if (!showConfirm)
        {
            <button class="inline-flex w-full items-center justify-center rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-500 transition-colors disabled:opacity-50" @onclick="PrepareDelete" disabled="@isDeleting">
                Delete Item
            </button>
        }
        else
        {
            <div class="rounded-md border border-red-700 bg-red-900/50 p-4 text-center text-red-200">
                <h6 class="font-semibold">Are you sure you want to delete item #@targetId?</h6>
                <div class="mt-3 flex justify-around">
                    <button class="inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-500 transition-colors disabled:opacity-50" @onclick="ConfirmDelete" disabled="@isDeleting">
                        @(isDeleting ? "Deleting..." : "Yes, Delete")
                    </button>
                    <button class="inline-flex items-center rounded-md bg-gray-600 px-4 py-2 text-sm font-medium text-white hover:bg-gray-500 transition-colors disabled:opacity-50" @onclick="CancelDelete" disabled="@isDeleting">
                        Cancel
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private int targetId;
    private bool showConfirm = false;
    private bool isDeleting = false;
    private string statusMessage = "";

    private void PrepareDelete()
    {
        if (targetId <= 0)
        {
            statusMessage = "❌ Please enter a valid ID.";
            return;
        }
        statusMessage = "";
        showConfirm = true; 
    }

    private async Task ConfirmDelete()
    {
        isDeleting = true;
        statusMessage = "Deleting item...";

        try
        {
            await _todoClientService.DeleteAsync(targetId);
            
            statusMessage = $"🗑️ Todo item #{targetId} deleted successfully!";
            targetId = 0;
            showConfirm = false;

            await Task.Delay(2000);
            NavigationManager.NavigateTo("/get-all-todos");

        }
        catch (Exception ex)
        {
            statusMessage = $"❌ Error deleting item: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void CancelDelete()
    {
        showConfirm = false;
        statusMessage = "Delete canceled.";
    }
}
