@page "/create-todo"

@inject ITodoClientService _todoClientService
@inject NavigationManager NavigationManager
@attribute [Authorize]

<div class="mx-auto mt-4" style="max-width: 500px;">
    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Create New Todo Item</h3>

    @if (hasError)
    {
        <div class="mt-3 rounded-md border border-red-700 bg-red-900/50 p-4 text-red-200">
            ❌ @errorMessage
        </div>
    }
    else if (isSuccess)
    {
        <div class="mt-3 rounded-md border border-green-700 bg-green-900/50 p-4 text-green-200">
            🎉 Todo item created successfully!
        </div>
        <div class="mt-2 rounded-md border p-4 @(calendarSynced ? "border-blue-700 bg-blue-900/50 text-blue-200" : "border-yellow-700 bg-yellow-900/50 text-yellow-200")">
            @(calendarSynced ? "✅" : "⚠️") @calendarMessage
        </div>
    }

    <EditForm Model="@newTodo" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-red-400" />

        <div class="mb-3">
            <label for="title" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Title:</label>
            <InputText id="title" @bind-Value="newTodo.Title" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-400 sm:text-sm" placeholder="Enter title..." required />
        </div>

        <div class="mb-3">
            <label for="description" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Description:</label>
            <InputText id="description" @bind-Value="newTodo.Description" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-400 sm:text-sm" placeholder="Enter Description..." />
        </div>

        <div class="mb-3 flex items-center gap-2">
            <InputCheckbox id="isComplete" @bind-Value="newTodo.IsComplete" class="size-4 rounded border-gray-300 bg-white text-indigo-600 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800" />
            <label for="isComplete" class="text-sm text-gray-700 dark:text-gray-300">Is Completed?</label>
        </div>

        <div class="mb-3">
            <label class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">تاريخ ووقت البداية</label>
            <input type="datetime-local"
                value="@newTodo.StartDateTime.ToString("yyyy-MM-ddTHH:mm")"
                @onchange="@(e => newTodo.StartDateTime = DateTimeOffset.Parse(e.Value?.ToString() ?? string.Empty))"
                class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white sm:text-sm" />
        </div>

        <div class="mb-3">
            <label class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">تاريخ ووقت النهاية</label>
            <input type="datetime-local"
                value="@newTodo.EndDateTime.ToString("yyyy-MM-ddTHH:mm")"
                @onchange="@(e => newTodo.EndDateTime = DateTimeOffset.Parse(e.Value?.ToString() ?? string.Empty))"
                class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white sm:text-sm" />
        </div>

        <button type="submit" class="inline-flex items-center rounded-md bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-500 transition-colors disabled:opacity-50" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span>Saving...</span>
            }
            else
            {
                <span>Create Todo</span>
            }
        </button>
    </EditForm>
</div>

@code {
    private TodoDTO newTodo = new TodoDTO();

    private bool isSubmitting = false;
    private bool isSuccess = false;
    private bool hasError = false;
    private string errorMessage = "";
    private bool calendarSynced = false;
    private string calendarMessage = "";

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        isSuccess = false;
        hasError = false;
        errorMessage = "";
        calendarSynced = false;
        calendarMessage = "";

        try
        {
            var result = await _todoClientService.CreateAsync(newTodo);

            if (result.Success)
            {
                isSuccess = true;
                calendarSynced = result.CalendarSynced;
                calendarMessage = result.CalendarMessage;

                newTodo = new TodoDTO();
                StateHasChanged();

                await Task.Delay(3000);
                NavigationManager.NavigateTo("/get-all-todos");
            }
            else
            {
                hasError = true;
                errorMessage = $"Failed. Please Try Again! ({result.CalendarMessage})";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating todo: {ex.Message}");
            hasError = true;
            errorMessage = $"Error: {ex.Message}";
            await Task.Delay(3000);
            NavigationManager.NavigateTo("/get-all-todos");
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
