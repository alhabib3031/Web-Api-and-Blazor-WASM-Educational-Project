@page "/create-todo"

@inject ITodoClientService _todoClientService
@inject NavigationManager NavigationManager
@attribute [Authorize]

<div class="container mt-4" style="max-width: 500px;">
    <h3>Create New Todo Item</h3>

    @if (hasError)
    {
        <div class="alert alert-danger">
            ❌ @errorMessage
        </div>
    }
    else if (isSuccess)
    {
        <div class="alert alert-success">
            🎉 Todo item created successfully!
        </div>
        <div class="alert @(calendarSynced ? "alert-info" : "alert-warning")">
            @(calendarSynced ? "✅" : "⚠️") @calendarMessage
        </div>
    }

    <EditForm Model="@newTodo" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />

        <div class="form-group mb-3">
            <label for="title" class="form-label">Title:</label>
            <InputText id="title" @bind-Value="newTodo.Title" class="form-control" placeholder="Enter title..." required />
        </div>

        <div class="form-group mb-3">
            <label for="description" class="form-label">Description:</label>
            <InputText id="description" @bind-Value="newTodo.Description" class="form-control" placeholder="Enter Description..." />
        </div>

        <div class="form-check mb-3">
            <InputCheckbox id="isComplete" @bind-Value="newTodo.IsComplete" class="form-check-input" />
            <label for="isComplete" class="form-check-label">Is Completed?</label>
        </div>

        <div class="mb-3">
            <label class="form-label">تاريخ ووقت البداية</label>
            <input type="datetime-local"
                value="@newTodo.StartDateTime.ToString("yyyy-MM-ddTHH:mm")"
                @onchange="@(e => newTodo.StartDateTime = DateTimeOffset.Parse(e.Value?.ToString() ?? string.Empty))"
                class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">تاريخ ووقت النهاية</label>
            <input type="datetime-local"
                value="@newTodo.EndDateTime.ToString("yyyy-MM-ddTHH:mm")"
                @onchange="@(e => newTodo.EndDateTime = DateTimeOffset.Parse(e.Value?.ToString() ?? string.Empty))"
                class="form-control" />
        </div>

        <button type="submit" class="btn btn-success" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span>Saving...</span>
            }
            else
            {
                <span>Create Todo</span>
            }
        </button>
    </EditForm>
</div>

@code {
    private TodoDTO newTodo = new TodoDTO();

    private bool isSubmitting = false;
    private bool isSuccess = false;
    private bool hasError = false;
    private string errorMessage = "";
    private bool calendarSynced = false;
    private string calendarMessage = "";

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        isSuccess = false;
        hasError = false;
        errorMessage = "";
        calendarSynced = false;
        calendarMessage = "";

        try
        {
            var result = await _todoClientService.CreateAsync(newTodo);

            if (result.Success)
            {
                isSuccess = true;
                calendarSynced = result.CalendarSynced;
                calendarMessage = result.CalendarMessage;

                newTodo = new TodoDTO();
                StateHasChanged();

                await Task.Delay(3000);
                NavigationManager.NavigateTo("/get-all-todos");
            }
            else
            {
                hasError = true;
                errorMessage = $"Failed. Please Try Again! ({result.CalendarMessage})";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating todo: {ex.Message}");
            hasError = true;
            errorMessage = $"Error: {ex.Message}";
            await Task.Delay(3000);
            NavigationManager.NavigateTo("/get-all-todos");
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
