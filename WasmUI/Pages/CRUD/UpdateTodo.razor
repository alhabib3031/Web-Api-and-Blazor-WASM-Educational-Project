@page "/update-todo"

@inject NavigationManager NavigationManager
@inject ITodoClientService _todoClientService 
@attribute [Authorize]


<div class="mx-auto mt-4" style="max-width: 500px;">
    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Update Todo Item</h3>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="mt-3 rounded-md border border-blue-700 bg-blue-900/50 p-4 text-blue-200">@statusMessage</div>
    }

    <div class="mb-4 rounded-lg bg-white p-4 shadow-md dark:bg-gray-800">
        <h5 class="font-semibold text-gray-900 dark:text-white">1. Load Item by ID</h5>
        <div class="mt-2 flex gap-2">
            <input type="number" @bind="searchId" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-400 sm:text-sm" placeholder="Enter ID to edit..." />
            <button class="inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 transition-colors disabled:opacity-50" @onclick="FetchTodo" disabled="@isLoading">Load</button>
        </div>
    </div>

    @if (todoToEdit != null)
    {
        <div class="rounded-lg bg-white p-4 shadow-md dark:bg-gray-800">
            <h5 class="font-semibold text-gray-900 dark:text-white">2. Edit Details</h5>
            <EditForm Model="@todoToEdit" OnValidSubmit="HandleUpdate">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-red-400" />

                <div class="mb-3">
                    <label for="editTitle" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Title:</label>
                    <InputText id="editTitle" @bind-Value="todoToEdit.Title" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-400 sm:text-sm" required />
                </div>

                <div class="mb-3 flex items-center gap-2">
                    <InputCheckbox id="editIsComplete" @bind-Value="todoToEdit.IsComplete" class="size-4 rounded border-gray-300 bg-white text-indigo-600 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800" />
                    <label for="editIsComplete" class="text-sm text-gray-700 dark:text-gray-300">Is Completed?</label>
                </div>

                <button type="submit" class="inline-flex w-full items-center justify-center rounded-md bg-yellow-600 px-4 py-2 text-sm font-medium text-white hover:bg-yellow-500 transition-colors disabled:opacity-50" disabled="@isProcessing">
                    @(isProcessing ? "Updating..." : "Save Changes")
                </button>
            </EditForm>
        </div>
    }
</div>

@code {
    private int searchId;
    private TodoDTO? todoToEdit;
    private bool isLoading = false;
    private bool isProcessing = false;
    private string statusMessage = "";

    private async Task FetchTodo()
    {
        if (searchId <= 0) { statusMessage = "❌ Please enter a valid ID."; return; }
        isLoading = true;
        statusMessage = "Loading...";
        todoToEdit = null;

        try
        {
            todoToEdit = await _todoClientService.GetTodosAsync(searchId);
            statusMessage = todoToEdit == null ? "❌ Item not found." : "✅ Item loaded successfully.";
        }
        catch (Exception ex) { statusMessage = $"❌ Error: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private async Task HandleUpdate()
    {
        isProcessing = true;
        try
        {
            await _todoClientService.UpdateAsync(searchId, todoToEdit!);
            statusMessage = "🎉 Todo item updated successfully!";

            await Task.Delay(2000);
            NavigationManager.NavigateTo("/get-all-todos");

        }
        catch (Exception ex) { statusMessage = $"❌ Error updating: {ex.Message}"; }
        finally { isProcessing = false; }
    }
}
