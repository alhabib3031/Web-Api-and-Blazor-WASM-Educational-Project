@page "/get-all-todos"

@inject ITodoClientService _todoClientService 
@attribute [Authorize]


<h3 class="text-xl font-bold text-gray-900 dark:text-white">Task Flow</h3>

@if (todos == null)
{
    <p class="text-gray-500 dark:text-gray-400"><em>Loading...</em></p>
}
else
{
    <div class="mt-4 grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-5">
        @foreach (var todo in todos)
        {
            <div class="rounded-xl bg-white p-5 shadow-sm dark:bg-gray-800 dark:shadow-md">
                <div class="flex items-center justify-between">
                    <h5 class="font-semibold text-gray-900 dark:text-white">@todo.Title</h5>

                    @if (todo.IsComplete)
                    {
                        <span class="rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900 dark:text-green-200">Completed</span>
                    }
                    else
                    {
                        <span class="rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">Pending</span>
                    }
                </div>

                <p class="mt-2 text-gray-600 dark:text-gray-400">
                    @(string.IsNullOrWhiteSpace(todo.Description)
                        ? "No Description"
                        : todo.Description)
                </p>

                <div class="mt-3 space-y-1 text-sm text-gray-500 dark:text-gray-500">
                    <div>
                        start 📅 @todo.StartDateTime.ToString("dd MMM yyyy")
                    </div>
                    <div>
                        end   📅 @todo.StartDateTime.ToString("dd MMM yyyy")
                    </div>
                </div>

            </div>
        }
    </div>
}

@code {
private List<TodoDTO>? todos;

    protected override async Task OnInitializedAsync()
    {
        todos = await _todoClientService.GetTodosAsync();
    }
}
