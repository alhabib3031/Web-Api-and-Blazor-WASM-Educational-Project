@page "/my-calendar"
@attribute [Authorize] 
@inject ITodoClientService service

<h3 class="mb-4">📅 مواعيدي القادمة من Google Calendar</h3>

@if (events == null)
{
    <div class="rounded-md border border-blue-700 bg-blue-900/50 p-4 text-blue-200">جاري تحميل المواعيد من حساب جوجل الخاص بك...</div>
}
else if (!events.Any())
{
    <div class="rounded-md border border-yellow-700 bg-yellow-900/50 p-4 text-yellow-200">لا توجد مواعيد قادمة في تقويمك حالياً.</div>
}
else
{
    <div class="overflow-x-auto rounded-lg border border-gray-700">
        <table class="w-full text-left">
            <thead class="bg-gray-800 text-white">
                <tr>
                    <th class="px-4 py-3">عنوان الموعد</th>
                    <th class="px-4 py-3">وقت البداية</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-700 [&amp;>tr:nth-child(even)]:bg-gray-800/50 [&amp;>tr:hover]:bg-gray-700/50">
                @foreach (var ev in events)
                {
                    <tr>
                        <td class="px-4 py-3"><strong>@ev.Title</strong></td>
                        <td class="px-4 py-3">@ev.StartTime.ToString("dd/MM/yyyy hh:mm tt")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {


    private List<CalendarEventDto>? events;

    protected override async Task OnInitializedAsync()
    {
        events = await service.GetUserCalendar();
    }

}
